# C.Y.R.U.S. System Configuration
# ==========================================
# WARNING: DO NOT commit your actual .env file.
# This file is just a template. Create a copy named '.env' and add your keys there.

# 1. API KEY (Required)
# Get your Gemini API key from Google AI Studio. 
# Providing it here sets the system default. Users can also enter their own keys in the app settings.
GEMINI_API_KEY="your_api_key_here"
OPENAI_API_KEY="optional"
ANTHROPIC_API_KEY="optional"

# 2. DATABASE OVERRIDE (Optional)
# By default, C.Y.R.U.S. uses local browser storage.
# If you want to connect to a custom database, provide your Database URL below.
# Supported types: "mongodb", "postgres", "mysql"
# DATABASE_TYPE="mongodb" 
# DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/cyrus?retryWrites=true&w=majority"

